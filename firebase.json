{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "faujiniwas",
      "public": "faujiadda-app/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|png|jpg|webp|svg)",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        },
        {
          "source": "**",
          "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
        }
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "/home.html",
          "type": 302
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "faujirentals",
      "public": "faujiadda-app/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|png|jpg|webp|svg)",
          "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }]
        }
      ],
      "redirects": [
        {
          "source": "/",
          "destination": "/home.html",
          "type": 302
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
